# ── Database ─────────────────────────────────────────────────
# Local dev: SQLite (zero dependencies)
# Production: Fly Postgres — provisioned via scripts/provision-fly-resources.sh
DATABASE_URL=file:dev.db

# Redis (cache / background jobs)
# Local dev: optional (app works without Redis)
# Production: Upstash Redis — provisioned via https://console.upstash.com
REDIS_URL=redis://localhost:6379

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST_URL=http://localhost:3000

# ── GitHub App (OAuth + Webhooks) ───────────────────────────
# Create a GitHub App: https://github.com/settings/apps
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# ── AI (Anthropic Claude) ───────────────────────────────────
# Optional — changelog generation falls back to no AI when unset
ANTHROPIC_API_KEY=

# ── Error tracking (optional) ───────────────────────────────
SENTRY_DSN=

# ── Email (SMTP) ──────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=changelog@devcomms.ai

# ── Slack ──────────────────────────────────────────────────────
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_WEBHOOK_URL=

# ── Stripe (optional in dev) ───────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
