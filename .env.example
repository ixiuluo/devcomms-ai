# ── Database ─────────────────────────────────────────────────
# Local dev: SQLite (zero dependencies)
# Production: postgresql://user:pass@host:5432/dra
DATABASE_URL=file:dev.db

# Redis (cache / background jobs — optional in dev)
REDIS_URL=redis://localhost:6379

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST_URL=http://localhost:3000

# ── GitHub App (OAuth + Webhooks) ───────────────────────────
# Create a GitHub App: https://github.com/settings/apps
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# ── AI (Anthropic Claude) ───────────────────────────────────
# Optional — changelog generation falls back to no AI when unset
ANTHROPIC_API_KEY=

# ── Error tracking (optional) ───────────────────────────────
SENTRY_DSN=

# ── Stripe (optional in dev) ────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
