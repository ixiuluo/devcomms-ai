generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ── Core ──────────────────────────────────────────────────────

model Team {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users              User[]
  githubRepos        GitHubRepo[]
  changelogs         Changelog[]
  slackIntegrations  SlackIntegration[]
  subscribers        Subscriber[]
  subscriptions      Subscription[]
  apiKeys            ApiKey[]

  @@map("teams")
}

model User {
  id        String   @id @default(uuid())
  teamId    String   @map("team_id")
  githubId  String?  @unique @map("github_id")
  email     String?
  name      String?
  avatarUrl String?  @map("avatar_url")
  role      String   @default("member") // owner, admin, member
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  team Team @relation(fields: [teamId], references: [id])

  @@map("users")
}

// ── GitHub Integration ───────────────────────────────────────

model GitHubRepo {
  id            String    @id @default(uuid())
  teamId        String    @map("team_id")
  githubId      Int       @map("github_id")
  owner         String
  name          String
  fullName      String    @unique @map("full_name")
  private       Boolean   @default(false)
  defaultBranch String    @default("main") @map("default_branch")
  webhookId     Int?      @map("webhook_id")
  webhookSecret String?   @map("webhook_secret")
  connectedAt   DateTime  @default(now()) @map("connected_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  team       Team        @relation(fields: [teamId], references: [id])
  commits    Commit[]
  changelogs Changelog[]

  @@map("github_repos")
}

model Commit {
  id          String   @id @default(uuid())
  repoId      String   @map("repo_id")
  sha         String
  message     String
  authorName  String?  @map("author_name")
  authorEmail String?  @map("author_email")
  committedAt DateTime @map("committed_at")
  prNumber    Int?     @map("pr_number")
  prTitle     String?  @map("pr_title")
  prBody      String?  @map("pr_body")
  createdAt   DateTime @default(now()) @map("created_at")

  repo  GitHubRepo @relation(fields: [repoId], references: [id])
  entries Entry[]

  @@unique([repoId, sha])
  @@map("commits")
}

// ── Changelog ─────────────────────────────────────────────────

model Changelog {
  id          String   @id @default(uuid())
  teamId      String   @map("team_id")
  repoId      String?  @map("repo_id")
  title       String
  slug        String
  description String?
  published   Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  team     Team        @relation(fields: [teamId], references: [id])
  repo     GitHubRepo? @relation(fields: [repoId], references: [id])
  entries  Entry[]
  releases Release[]

  @@unique([teamId, slug])
  @@map("changelogs")
}

model Entry {
  id          String   @id @default(uuid())
  changelogId String   @map("changelog_id")
  commitId    String?  @map("commit_id")
  releaseId   String?  @map("release_id")
  category    String   @default("changed") // added, changed, fixed, removed, deprecated, security
  title       String
  summary     String
  body        String?
  aiGenerated Boolean  @default(true) @map("ai_generated")
  aiModel     String?  @map("ai_model")
  approved    Boolean  @default(false)
  published   Boolean  @default(false)
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  changelog Changelog @relation(fields: [changelogId], references: [id])
  commit    Commit?   @relation(fields: [commitId], references: [id])
  release   Release?  @relation(fields: [releaseId], references: [id])

  @@map("entries")
}

model Release {
  id          String   @id @default(uuid())
  changelogId String   @map("changelog_id")
  version     String
  title       String?
  summary     String?
  aiGenerated Boolean  @default(true) @map("ai_generated")
  published   Boolean  @default(false)
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  changelog Changelog @relation(fields: [changelogId], references: [id])
  entries   Entry[]

  @@unique([changelogId, version])
  @@map("releases")
}

// ── Subscribers & Notifications ──────────────────────────────

model Subscriber {
  id        String    @id @default(uuid())
  teamId    String    @map("team_id")
  email     String
  verified  Boolean   @default(false)
  token     String    @unique // unsubscribe token
  createdAt DateTime  @default(now()) @map("created_at")
  unsubscribedAt DateTime? @map("unsubscribed_at")

  team Team @relation(fields: [teamId], references: [id])

  @@unique([teamId, email])
  @@map("subscribers")
}

model SlackIntegration {
  id        String   @id @default(uuid())
  teamId    String   @map("team_id")
  webhookUrl String  @map("webhook_url")
  channel   String?
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  team Team @relation(fields: [teamId], references: [id])

  @@map("slack_integrations")
}

// ── Subscriptions ─────────────────────────────────────────────

model Subscription {
  id            String    @id @default(uuid())
  teamId        String    @unique @map("team_id")
  stripeCustomerId String? @map("stripe_customer_id")
  stripeSubscriptionId String? @map("stripe_subscription_id")
  plan          String    @default("free") // free, starter, pro, enterprise
  status        String    @default("active") // active, trialing, past_due, canceled, unpaid, incomplete
  currentPeriodStart DateTime? @map("current_period_start")
  currentPeriodEnd   DateTime? @map("current_period_end")
  trialEndsAt   DateTime? @map("trial_ends_at")
  canceledAt    DateTime? @map("canceled_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  team Team @relation(fields: [teamId], references: [id])

  @@map("subscriptions")
}

// ── API Keys ──────────────────────────────────────────────────

model ApiKey {
  id         String    @id @default(uuid())
  teamId     String    @map("team_id")
  name       String
  keyPrefix  String    @map("key_prefix") // first 8 chars, stored for identification
  keyHash    String    @map("key_hash")   // bcrypt hash
  lastUsedAt DateTime? @map("last_used_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  expiresAt  DateTime? @map("expires_at")

  team Team @relation(fields: [teamId], references: [id])

  @@map("api_keys")
}

// ── Analytics ─────────────────────────────────────────────────

model PageView {
  id         String   @id @default(uuid())
  changelogId String  @map("changelog_id")
  path       String
  referrer   String?
  userAgent  String?  @map("user_agent")
  ip         String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("page_views")
}
